{
  "name": "global-mood-map",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Real-time emotional weather for the planet — anonymous mood reporting on a live world map.",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "compression": "1.7.5",
    "express": "4.21.2",
    "geoip-lite": "1.4.10",
    "pngjs": "7.0.0",
    "tsx": "4.19.2",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/compression": "1.7.5",
    "@types/express": "4.17.21",
    "@types/geoip-lite": "1.4.4",
    "@types/node": "22.10.5",
    "@types/pngjs": "6.0.5",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@types/supertest": "6.0.2",
    "@vitejs/plugin-react": "4.3.4",
    "concurrently": "9.1.2",
    "maplibre-gl": "4.7.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "supertest": "7.0.0",
    "typescript": "5.7.3",
    "vite": "5.4.11",
    "vitest": "2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
